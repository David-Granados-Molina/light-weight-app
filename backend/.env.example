DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db"
PORT=3000
CORS_ORIGIN="http://localhost:4200"
FRONTEND_URL="http://localhost:4200"

# Secreto para firmar los tokens de sesión (JWT). Cadena aleatoria larga;
# no la compartas ni la subas a un repositorio público.
JWT_SECRET=
# Duración de la sesión antes de tener que volver a iniciar sesión.
JWT_EXPIRES_IN=180d

# Login con Google: Client ID de tu proyecto en Google Cloud Console
# (debe ser el MISMO que se use en frontend/src/app/core/config/auth.config.ts).
GOOGLE_CLIENT_ID=

# Email del usuario admin: ve la pantalla de "Amigos" en el perfil para consultar
# el historial y progreso del resto de usuarios.
ADMIN_EMAIL=

# Envío del email de "recuperar/crear contraseña" vía Resend (HTTPS, no SMTP).
# Crea una cuenta gratis en https://resend.com y genera una API key.
RESEND_API_KEY=
