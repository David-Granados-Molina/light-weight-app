DATABASE_URL="file:./dev.db"
PORT=3000
CORS_ORIGIN="http://localhost:4200"
FRONTEND_URL="http://localhost:4200"

# Necesaria para el registro de entrenos por WhatsApp (ver README de backend).
# Crea una clave en https://console.anthropic.com/ y pégala aquí.
ANTHROPIC_API_KEY=

# Secreto para firmar los tokens de sesión (JWT). Cadena aleatoria larga;
# no la compartas ni la subas a un repositorio público.
JWT_SECRET=
# Duración de la sesión antes de tener que volver a iniciar sesión.
JWT_EXPIRES_IN=180d

# Login con Google: Client ID de tu proyecto en Google Cloud Console
# (debe ser el MISMO que se use en frontend/src/app/core/config/auth.config.ts).
GOOGLE_CLIENT_ID=

# Envío del email de "recuperar contraseña" vía Gmail SMTP.
# SMTP_USER: tu cuenta de Gmail. SMTP_PASS: una "contraseña de aplicación"
# generada en https://myaccount.google.com/apppasswords (no tu contraseña normal).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
